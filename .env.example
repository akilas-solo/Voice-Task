# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# DATABASE_NAME: The Room sqlite database file designation
DATABASE_NAME=voistask_database

# SECURITY_MODE_ENABLED: Enable secure PIN passcode lock on launchscreen
SECURITY_MODE_ENABLED=true

# APP_SECURE_PASSCODE: 4-digit numeric passcode to unlock database memos
APP_SECURE_PASSCODE=1234
